JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=your-api-token
JIRA_START_DATE_FIELD=customfield_XXXXX   # e.g. customfield_10039 — look up via /rest/api/3/field
JIRA_DUE_DATE_FIELD=duedate
JIRA_PROJECT_TYPE=nextgen   # or: classic
JIRA_PROJECT_KEY=MTC        # optional — used by "Create Model Epic" when no Feature ID is provided
